#!/bin/bash

echo "--- Starting Universal Puchi Code Setup ---"

# 1. Environment Detection
if [ -d "/data/data/com.termux/files/usr" ]; then
    IS_TERMUX=true
    INSTALL_CMD="pkg install -y"
    UPDATE_CMD="pkg update && pkg upgrade -y"
    echo "Environment: Termux detected"
else
    IS_TERMUX=false
    INSTALL_CMD="sudo apt-get install -y"
    UPDATE_CMD="sudo apt-get update && sudo apt-get upgrade -y"
    echo "Environment: Linux/WSL detected"
fi

# 2. Update and install basic packages
echo "Installing essential packages..."
$UPDATE_CMD
if [ "$IS_TERMUX" = true ]; then
    $INSTALL_CMD git tmux tur-repo zsh tailscale rustdesk-server python termux-api
else
    $INSTALL_CMD git tmux zsh curl python3
    if ! command -v tailscale &> /dev/null; then
        curl -fsSL https://tailscale.com/install.sh | sh
    fi
fi

# 3. Setup Tailscale
echo "Setting up Tailscale..."
if [ "$IS_TERMUX" = true ]; then
    if ! pgrep tailscaled > /dev/null; then
        nohup tailscaled --tun=userspace-networking --socket=$HOME/tailscaled.sock --state=$HOME/tailscale/tailscaled.state --port=41641 > $HOME/tailscaled.log 2>&1 &
        sleep 2
    fi
else
    sudo systemctl enable --now tailscaled
fi

# 4. Setup RustDesk Server & Status API in Tmux
echo "Configuring Services in Tmux..."
if ! tmux has-session -t rustdesk 2>/dev/null; then
    tmux new-session -s rustdesk -n 'hbbs' -d
    if command -v hbbs &> /dev/null; then
        tmux send-keys -t rustdesk:0 "cd ~/rustdesk-server && ./hbbs -p 31116" C-m
    fi
    
    tmux new-window -t rustdesk -n 'hbbr'
    if command -v hbbr &> /dev/null; then
        tmux send-keys -t rustdesk:1 "cd ~/rustdesk-server && ./hbbr -p 31117" C-m
    fi

    # Start Status API
    tmux new-window -t rustdesk -n 'api'
    if [ -f "$HOME/puchi_api.py" ]; then
        tmux send-keys -t rustdesk:2 "python ~/puchi_api.py" C-m
    fi
    echo "Services started in tmux session 'rustdesk'"
fi

# 5. Dotfiles Management
if [ ! -d "$HOME/dotfiles" ]; then
    echo "Cloning dotfiles repository..."
    git clone https://github.com/Jcthatkid/dotfiles.git $HOME/dotfiles
    cd $HOME/dotfiles && git branch --set-upstream-to=origin/main main
else
    echo "Updating dotfiles..."
    cd $HOME/dotfiles
    git branch --set-upstream-to=origin/main main 2>/dev/null
    git pull
fi

# 6. Apply Symlinks
echo "Applying symlinks..."
ln -sf $HOME/dotfiles/.zshrc $HOME/.zshrc
ln -sf $HOME/dotfiles/.tmux.conf $HOME/.tmux.conf

# 7. Notify Completion
if command -v puchinotify &> /dev/null; then
    puchinotify "Puchi System Online on $(hostname)!"
fi

echo "--- Puchi Code Execution Complete ---"
echo "You can now run 'tmux attach -t rustdesk' to see your servers."
